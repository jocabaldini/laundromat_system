generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  OPERATOR
  USER
}

model User {
  id               String    @id @default(cuid())
  email            String    @unique
  name             String?
  passwordHash     String
  refreshTokenHash String?
  role             Role      @default(USER)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
}

model Customer {
  id            String         @id @default(cuid())
  code          String         @unique
  name          String
  phone         String?
  email         String?
  address       String?
  deletedAt     DateTime?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  serviceOrders ServiceOrder[]

  @@index([name])
  @@index([deletedAt])
}

enum PricingType {
  POR_KG
  POR_UNIDADE
}

model ServiceItem {
  id        String      @id @default(cuid())
  name      String      @unique
  type      PricingType
  price     Decimal     @db.Decimal(10, 2)
  deletedAt DateTime?
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  @@index([deletedAt])
}

enum ServiceOrderStatus {
  RECEIVED
  WASHING
  IRONING
  READY
  DELIVERED
  CANCELLED
}

enum ServiceOrderItemStatus {
  RECEIVED
  WASHING
  IRONING
  READY
}

model ServiceOrder {
  id                  String             @id @default(cuid())
  customerId          String
  customer            Customer           @relation(fields: [customerId], references: [id])
  status              ServiceOrderStatus @default(RECEIVED)
  estimatedDeliveryAt DateTime
  observations        String?
  referenceTotal      Decimal            @db.Decimal(10, 2)
  finalTotal          Decimal            @db.Decimal(10, 2)
  discount            Decimal            @default(0) @db.Decimal(10, 2)
  items               ServiceOrderItem[]
  deletedAt           DateTime?
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt

  @@index([customerId])
  @@index([status])
  @@index([estimatedDeliveryAt])
  @@index([deletedAt])
}

model ServiceOrderItem {
  id              String                 @id @default(cuid())
  serviceOrderId  String
  serviceOrder    ServiceOrder           @relation(fields: [serviceOrderId], references: [id])
  serviceItemId   String
  serviceItemName String // snapshot — immutable after creation
  serviceItemType PricingType // snapshot — immutable after creation
  referencePrice  Decimal                @db.Decimal(10, 2) // snapshot — immutable after creation
  finalPrice      Decimal                @db.Decimal(10, 2) // editable by operator
  quantity        Decimal                @db.Decimal(10, 3) // kg (decimal) or units (integer stored as decimal)
  status          ServiceOrderItemStatus @default(RECEIVED)
  observations    String?
  createdAt       DateTime               @default(now())
  updatedAt       DateTime               @updatedAt

  @@index([serviceOrderId])
  @@index([serviceItemId])
}
